# Local FastAPI — copy to backend/.env (uvicorn from backend/)
# Same variable names as Vercel Python function — see ../vercel/env.example

CORS_ORIGINS=http://localhost:3000

DATABASE_URL=sqlite:///./data/caretriage.db
# Production / Supabase: use Postgres URI (see vercel/env.example)

CLERK_JWKS_URL=https://YOUR_SUBDOMAIN.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://YOUR_SUBDOMAIN.clerk.accounts.dev

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=60

FREE_TIER_MONTHLY_INTAKES=20

# Optional
# APP_NAME=CareTriage AI API
